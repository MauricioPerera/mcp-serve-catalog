{
  "name": "mcp-serve-catalog",
  "version": "0.0.0",
  "private": true,
  "description": "Stateless MCP server that exposes an a2e-skills catalog to any MCP-compliant client. Zero runtime deps.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-serve-catalog": "dist/bin/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "prepack": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.11.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "catalog",
    "a2e-skills",
    "stateless",
    "json-rpc",
    "adapter"
  ],
  "license": "MIT"
}
